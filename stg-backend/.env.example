# =============================================================================
# STG-Ashland Backend — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in production values before launch.
# NEVER commit .env files to version control.

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stg_ashland
POOL_MIN=2
POOL_MAX=25
POOL_ACQUIRE_TIMEOUT_MS=5000

# --- gRPC Server ---
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_BIND_ADDR=0.0.0.0:50051

# --- HTTP Health/Metrics (future) ---
HTTP_PORT=9090

# --- Server Identity ---
SERVER_ID=ashland-server-01
SERVER_TOKEN=change-me-in-production
WORLD_ID=ashland-overworld

# --- Heartbeat & Cleanup ---
HEARTBEAT_INTERVAL_SEC=30
CLEANUP_RETENTION_DAYS=7

# --- Logging ---
LOG_LEVEL=info
