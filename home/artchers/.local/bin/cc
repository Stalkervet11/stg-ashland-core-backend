#!/bin/bash
# Wrapper: forward all args to ld, translating gcc arch flags to ld emulation.
# This handles the Rust compiler's -m64 flag which ld.bfd 2.46+ doesn't support directly.
ARGS=()
skip_next=false
for arg in "$@"; do
  if $skip_next; then skip_next=false; continue; fi
  case "$arg" in
    -m64)    ARGS+=("-m" "elf_x86_64") ;;
    -m32)    ARGS+=("-m" "elf_i386") ;;
    -m*)     ARGS+=("$arg") ;;
    -fuse-ld=*) ;; # Skip, we use ld directly
    -B*/bin/gcc-ld) ;; # Skip sysroot gcc-ld
    -Wl,*)   IFS=',' read -ra X <<< "${arg#-Wl,}"; for x in "${X[@]}"; do ARGS+=("$x"); done ;;
    -z)      ARGS+=("$arg"); skip_next=true ;;
    *)       ARGS+=("$arg") ;;
  esac
done
exec /usr/bin/ld "${ARGS[@]}"
